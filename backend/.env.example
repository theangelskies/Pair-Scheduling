# Copy this file to .env and fill in your values.
# Never commit .env to git!

PORT=3000

# postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/appdb

# Origin allowed to call this API (your deployed frontend URL in production)
FRONTEND_URL=http://localhost:5173

# Supabase project ref used for JWT verification.
# Example: if your URL is https://abc123.supabase.co, use SUPABASE_PROJECT=abc123.
SUPABASE_PROJECT=your-supabase-project-ref
