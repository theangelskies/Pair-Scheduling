{
  "name": "Pair-Scheduling-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "oxlint src",
    "format": "oxfmt",
    "typecheck": "tsc --noEmit",
    "migrate": "dotenv -e .env -- node-pg-migrate up -m migrations",
    "migrate:down": "dotenv -e .env -- node-pg-migrate down -m migrations",
    "migrate:create": "node-pg-migrate create -m migrations",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  }
}
